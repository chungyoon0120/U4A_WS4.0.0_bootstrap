{
  "name": "com.u4a_ws3.app",
  "version": "3.6.3",
  "displayName": "U4A Workspace",
  "description": "U4A Application for Integrated Development of Web Environments Developed by the U4A Solution RnD Team.",
  "main": "electron/main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "build": "npm run postinstall && npm run build:win",
    "build:win": "electron-builder --win --x64",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [],
  "author": "U4A Solution R&D Team",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "^14.2.9",
    "electron-builder": "^26.0.12"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LEECHUNGYOON/U4A_WS3.0.0.git"
  },
  "build": {
    "appId": "com.u4a_ws3.app",
    "productName": "U4A Workspace",
    "nsis": {
      "shortcutName": "U4A Workspace",
      "installerIcon": "www/img/logo.ico",
      "deleteAppDataOnUninstall": true,
      "include": "www/ext_api/nsh/u4a-nsis-hooks.nsh",
      "allowToChangeInstallationDirectory": false,
      "oneClick": true,
      "perMachine": false
    },
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "copyright": "Copyright 2020. INFOCG Inc. all rights reserved.",
    "artifactName": "U4A-Workspace-Setup-${version}.${ext}",
    "win": {
      "icon": "www/img/logo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github"
    },
    "files": [
      "electron/**/*",
      "www/**/*",
      "package.json",
      "!www/**/_*.*",
      "!www/**/_*/**"
    ],    
    "asarUnpack": [
      "**/node_modules/@electron/remote/**/*"
    ],
    "extraResources": [
      "./node_modules/**/*",
      "./node_modules/@electron/remote/**",
      "./www/ext_api/nsh/**",
      "./www/MSG",
      {
        "from": "node_modules/U4A",
        "to": "node_modules/U4A",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/regedit/vbs",
        "to": "regedit/vbs",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@electron/asar": "^3.4.1",
    "@electron/remote": "^2.1.3",
    "@octokit/core": "^3.6.0",
    "adm-zip": "^0.5.10",
    "arraybuffer-to-buffer": "^0.0.7",
    "basic-ftp": "^5.0.2",
    "better-sqlite3": "^12.9.0",
    "child_process": "^1.0.2",
    "dicer": "^0.3.1",
    "directory-tree": "^3.6.0",
    "electron-log": "^4.4.8",
    "electron-updater": "^5.0.1",
    "electron-window-state": "^5.0.3",
    "exceljs": "^4.3.0",
    "express": "^5.2.1",
    "fs-extra": "^10.1.0",
    "gh-release-assets": "^2.0.1",
    "http": "^0.0.1-security",
    "mime-types": "^2.1.35",
    "mongodb": "^5.1.0",
    "ncp": "^2.0.0",
    "net": "^1.0.2",
    "nircmd": "^2.0.0",
    "node-cmd": "^5.0.0",
    "node-screen": "^0.0.12",
    "node-ssh": "^13.0.1",
    "node-zip": "^1.1.1",
    "ping": "^0.4.2",
    "proper-lockfile": "^4.1.2",
    "puppeteer-core": "^20.7.2",
    "random-key": "^0.3.2",
    "regedit": "^5.0.0",
    "systeminformation": "^5.15.1",
    "ws": "^8.13.0",
    "xml-js": "^1.6.11",
    "yamljs": "^0.3.0",
    "zip-lib": "^0.7.3"
  }
}
